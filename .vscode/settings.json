// Local VS Code Extension Configurations
// Not used by Devcontainer instead configs are listed in .devcontainer/devcontainer.json
{
  // Editor rulers
  "editor.rulers": [
    { "column": 88, "color": "#737171" },
  ],
  "editor.tabSize": 2,

  // Color customizations (Default Dark Theme)
  "workbench.colorCustomizations": {
    "activityBar.background": "#181818",
    "titleBar.activeBackground": "#181818",
    "titleBar.activeForeground": "#cccccc"
  },  

  // Python formatting
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
  },
  // Python linting/formatting with Ruff
  "ruff.interpreter": [
    ".venv/Scripts/python",
    ".venv/bin/python",
  ],

  // Python Docstrings
  "autoDocstring.docstringFormat": "one-line-sphinx",
  
  // Python other settings
  "python.useEnvironmentsExtension": false, // Use Python Envy instead

  // YAML formatting
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[yml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  // TOML formatting
  "[toml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "evenBetterToml.formatter.allowedBlankLines": 2,

  // Markdown formatting
  "[markdown]":{
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  // Markdown Table of Contents settings
  "markdown.extension.toc.levels": "2..2",
  "markdown.extension.toc.updateOnSave": true,

  // Git
  "git.branchProtection": ["main"],
  "git.allowNoVerifyCommit": true,

  // Docker
  "containers.contexts.showInStatusBar": true,
  
}
